// Storage Security Rules for LokshinEats
// These rules control who can upload/download images

rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    // Images folder structure: images/{userId}/{filename}
    match /images/{userId}/{allPaths=**} {
      // Users can upload their own images
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Store images: stores/{storeId}/{filename}
    match /stores/{storeId}/{allPaths=**} {
      // Anyone can read store images
      allow read: if true;
      // Only store owners can upload
      allow write: if request.auth != null && 
        request.auth.uid == request.resource.metadata.ownerId;
    }
    
    // Product images: products/{productId}/{filename}
    match /products/{productId}/{allPaths=**} {
      // Anyone can read product images
      allow read: if true;
      // Only store owners can upload
      allow write: if request.auth != null;
    }
  }
}
